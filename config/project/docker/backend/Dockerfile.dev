# backend/Dockerfile.dev — 开发环境，增量编译
# 层缓存: requirements.txt 不变时，跳过 pip install

FROM python:3.11.6-slim

# 镜像源（与 env.sh 保持一致，network_mode: host 直达内网）
RUN pip config set global.index-url http://172.21.3.9:8081/repository/PyPI_group/simple \
    && pip config set global.trusted-host 172.21.3.9

WORKDIR /app

# ── 第一层: 依赖（很少变）──
# 只要 requirements.txt 没改，这层就命中缓存
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── 第二层: 代码（经常变）──
COPY . .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
