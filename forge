#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────
# forge - AI 工具版本管理器
#
# 用法:
#   forge                   检查并提示更新（类似 brew cu）
#   forge -a                检查并更新全部（类似 brew cu -a）
#   forge download            只下载不解压
#   forge install           安装环境无关工具（解压+git clone+字体+链接）
#   forge init              初始化环境依赖工具+配置
#   forge init tools|config|skills|mcp|bins  单步初始化
#   forge list              显示所有工具状态
#   forge pack [config|full] 打包用于迁移（config=仅配置，full=全量默认）
#   forge push <target>     打包并 scp 到远程服务器
#   forge update            仅检查可用更新
# ─────────────────────────────────────────────────────────
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

# 加载模块
for f in "$ROOT_DIR/shell/forge"/*.sh; do
    [ -f "$f" ] || continue
    source "$f"
done

# ── 主入口 ───────────────────────────────────────────────

case "${1:-}" in
    -a|--all)       cmd_check "true" ;;
    download)       shift; cmd_download "$@" ;;
    install)        shift; cmd_install "$@" ;;
    init)           shift; cmd_init "$@" ;;
    uninstall|rm)   shift; cmd_uninstall "$@" ;;
    list|ls)        cmd_list ;;
    update)         cmd_check "false" ;;
    new)            shift; cmd_new "$@" ;;
    pack)           shift; cmd_pack "$@" ;;
    merge)          shift; cmd_merge "$@" ;;
    push)           shift; cmd_push "$@" ;;
    skills)         shift; cmd_skills "$@" ;;
    mcp)            shift; cmd_mcp "$@" ;;
    doctor)         cmd_doctor ;;
    help|--help|-h) show_help ;;
    "")             cmd_check "false" ;;
    *)              show_help; exit 1 ;;
esac
